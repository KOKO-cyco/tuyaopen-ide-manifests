{
  "id": "graphics-lvgl-demo",
  "name": {
    "en": "LVGL Widgets Demo",
    "zh-CN": "LVGL 控件演示"
  },
  "summary": {
    "en": "Runs the built-in LVGL widgets demo on a display with touch and encoder support.",
    "zh-CN": "在屏幕上运行 LVGL 内置控件演示，支持触摸和编码器。"
  },
  "tags": [
    "example",
    "display",
    "lvgl"
  ],
  "compatibilityType": "board-specific",
  "boards": [
    "atk-t5ai-mini-board-rgb-md0700r",
    "atk-t5ai-mini-board-spi-md0240",
    "dnesp32s3-box",
    "esp32-bread-board",
    "t3-lcd-devkit-1-28",
    "tuya-t5ai-board-eyes",
    "tuya-t5ai-board-lcd-3-5",
    "tuya-t5ai-desktop-robot",
    "tuya-t5ai-evb",
    "tuya-t5ai-moji-1-28",
    "tuya-t5ai-pocket",
    "waveshare-t5ai-touch-amoled-1-75"
  ],
  "source": {
    "repo": "https://github.com/tuya/TuyaOpen",
    "subpath": "examples/graphics/lvgl_demo",
    "ref": "master"
  },
  "defaultConfig": {
    "ENABLE_LIBLVGL": "y",
    "LVGL_ENABLE_TP": "y",
    "ENABLE_LVGL_DEMO": "y"
  },
  "configs": {
