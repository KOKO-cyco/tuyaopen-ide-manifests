    "ETHARP_SUPPORT_STATIC_ENTRIES": "1",
    "LWIP_NETIF_STATUS_CALLBACK": "1",
    "LWIP_TIMEVAL_PRIVATE": "0",
    "IN_ADDR_T_DEFINED": "y"
  },
  "configs": {},
  "documentation": {
    "readme": {
      "en": "https://github.com/tuya/TuyaOpen/tree/master/examples/system/os_sw_timer/README.md",
