    "zh-CN": "创建周期性软件定时器，回调指定次数后停止。"
  },
  "tags": [
    "example",
    "system",
    "timer"
  ],
  "compatibilityType": "universal",
  "boards": [],
  "source": {
    "repo": "https://github.com/tuya/TuyaOpen",
    "subpath": "examples/system/os_sw_timer",
