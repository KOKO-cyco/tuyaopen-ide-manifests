            "zh-CN": "东山派 A1"
          },
          "peripherals": [
            "audio",
            "button"
          ]
        }
      ]
    }
  ],
  "documentation": {
    "readme": {
      "en": "https://github.com/tuya/VirtuaMate/blob/master/README.md",
      "zh-CN": "https://github.com/tuya/VirtuaMate/blob/master/README.md"
