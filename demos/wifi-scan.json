{
  "id": "wifi-scan",
  "name": {
    "en": "Wi-Fi Scan",
    "zh-CN": "Wi-Fi 扫描"
  },
  "summary": {
    "en": "Scans nearby Wi-Fi networks and reports channel numbers and SSIDs.",
    "zh-CN": "扫描附近 Wi-Fi 网络并输出信道号和 SSID。"
  },
  "tags": [
    "example",
    "wifi"
  ],
  "compatibilityType": "universal",
  "boards": [],
  "source": {
    "repo": "https://github.com/tuya/TuyaOpen",
    "subpath": "examples/wifi/scan",
    "ref": "master"
  },
  "defaultConfig": {
    "MEM_SIZE": "51200",
    "MEMP_NUM_UDP_PCB": "10",
    "MEMP_NUM_TCP_SEG": "80",
    "PBUF_LINK_ENCAPSULATION_HLEN": "96",
    "TCP_SND_BUF": "32768",
    "TCP_SND_QUEUELEN": "44",
    "MEMP_NUM_NETBUF": "32",
    "DEFAULT_UDP_RECVMBOX_SIZE": "24",
    "MEMP_NUM_SYS_TIMEOUT": "12",
    "LWIP_EAPOL_SUPPORT": "0",
    "LWIP_TX_PBUF_ZERO_COPY": "0",
    "CONFIG_TUYA_SOCK_SHIM": "0",
    "LWIP_DHCPC_STATIC_IPADDR_ENABLE": "1",
    "ETHARP_SUPPORT_STATIC_ENTRIES": "1",
    "LWIP_NETIF_STATUS_CALLBACK": "1",
    "LWIP_TIMEVAL_PRIVATE": "0",
    "IN_ADDR_T_DEFINED": "y"
  },
  "configs": {},
  "documentation": {
    "readme": {
      "en": "https://github.com/tuya/TuyaOpen/tree/master/examples/wifi/scan/README.md",
      "zh-CN": "https://github.com/tuya/TuyaOpen/tree/master/examples/wifi/scan/README_CN.md"
    }
  }
}
