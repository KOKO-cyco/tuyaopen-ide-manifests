{
  "id": "peripherals-camera-output-display",
  "source": "https://github.com/tuya/TuyaOpen/tree/master/examples/peripherals/camera/output_display",
  "configs": [
    {
      "board": "tuya-t5ai-board",
      "accessory": "group-mpxn93yq",
      "options": [
        {
          "file": "TUYA_T5AI_BOARD_CAMERA_LCD_3.5.config",
          "name": {
            "en": "3.5\" LCD + Camera",
            "zh-CN": "3.5寸 LCD + 摄像头"
          }
        }
      ]
    },
    {
      "board": "tuya-t5ai-pocket",
      "options": [
        {
          "file": "TUYA_T5AI_POCKET.config",
          "name": {
            "en": "Tuya T5AI Pocket",
            "zh-CN": "涂鸦 T5AI Pocket 板"
          }
        }
      ]
    },
    {
      "board": "atk-dnesp32s3",
      "options": [
        {
          "file": "DNESP32S3_CAMERA_LCD_MD0240_SPI.config",
          "name": {
            "en": "ALIENTEK DNESP32S3 (Camera + 2.4\" SPI LCD)",
            "zh-CN": "正点原子 DNESP32S3 (摄像头 + 2.4 寸 SPI LCD)"
          }
        }
      ]
    }
  ],
  "documentation": {
    "readme": {
      "zh-CN": "https://github.com/tuya/TuyaOpen/tree/master/examples/peripherals/camera/output_display/README_CN.md"
    }
  },
  "drivers": [
    {
      "driver": "camera",
      "level": "required"
    },
    {
      "driver": "display",
      "level": "required"
    }
  ]
}
