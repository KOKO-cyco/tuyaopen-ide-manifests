# Git configuration
GIT_REPO_PATH=../..
GIT_AUTHOR_NAME=Manifest Editor
GIT_AUTHOR_EMAIL=editor@tuyaopen.dev
GIT_BRANCH=main

# Server
PORT=3000
NODE_ENV=development
HOST=localhost

# Image storage
IMAGE_MAX_SIZE=5242880
IMAGE_QUALITY=85
IMAGE_MAX_WIDTH=500
IMAGE_MAX_HEIGHT=500

# Auto-git
AUTO_COMMIT=true
AUTO_PUSH=true
PUSH_INTERVAL=30000

# CORS
CORS_ORIGIN=http://localhost:3000
