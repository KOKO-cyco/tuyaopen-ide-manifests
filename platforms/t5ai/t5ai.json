  "flashAndDebug": {
    "flash": {
      "interface": "UART",
      "baudrate": {"default": 921600, "max": 2000000, "unit": "bps"},
      "pins": {"tx": 11, "rx": 10},
      "physicalPins": {"tx": 37, "rx": 36},
      "autoReset": true,
      "usbUart": {
        "channels": 2,
        "note": {
          "en": "Onboard dual-channel USB-to-UART chip; Channel 1 for flashing, Channel 2 for debug log.",
          "zh-CN": "板载双路 USB 转 UART 芯片；通道 1 用于烧录，通道 2 用于调试日志。"
        }
      },
      "guide": {
        "en": [
          "Open the serial debug tool from the TuyaOpen IDE menu to flash manually, or instruct the coding agent (e.g. Claude Code, Cursor) to auto-flash.",
          "The chip module uses UART protocol natively. The module itself has no USB-to-UART — use a dev board with onboard converter or an external USB-to-UART adapter.",
          "Flashing auto-resets via the dev board's USB-UART chip (no manual reset needed).",
          "Default baudrate 921600 bps (up to 2 Mbps)."
        ],
        "zh-CN": [
          "通过 TuyaOpen IDE 菜单打开串口调试工具进行手动烧写，或直接告诉 Coding Agent（如 Claude Code、Cursor）实现自动烧写。",
          "芯片模组本身使用 UART 协议，模组不带 USB 转 UART 芯片。可使用成品开发板上的板载转换芯片，或外接 USB 转 UART 适配器。",
          "烧录时通过开发板 USB-UART 芯片自动复位模组（无需手动复位）。",
          "默认波特率 921600 bps（最高支持 2 Mbps）。"
        ]
      }
    },
    "debug": {
      "interface": "UART2",
      "baudrate": {"default": 460800, "unit": "bps"},
      "pins": {"tx": 0, "rx": 1},
      "physicalPins": {"tx": 15, "rx": 12},
      "guide": {
        "en": [
          "Open the serial debug tool from the TuyaOpen IDE menu to view runtime logs.",
          "The second channel of the USB-UART chip serves as debug log output (UART1, 460800 bps).",
          "Log port: UART1 TX = GPIO0 (pin 15), RX = GPIO1 (pin 12)."
        ],
        "zh-CN": [
          "通过 TuyaOpen IDE 菜单打开串口调试工具查看运行日志。",
          "板载 USB 转 UART 芯片的第二通道作为调试日志输出（UART1，460800 bps）。",
          "日志端口：UART1 TX = GPIO0（管脚 15），RX = GPIO1（管脚 12）。"
        ]
      }
    }
  },
