{
  "schemaVersion": 1,
  "id": "t5ai-mini",
  "name": {
    "en": "T5AI Mini",
    "zh-CN": "T5AI Mini 开发板"
  },
  "summary": {
    "en": "Minimal T5AI board with audio AEC and optional SPI display expansion module",
    "zh-CN": "搭载音频 AEC 的 T5AI Mini 开发板，支持可选 SPI 显示扩展模块"
  },
  "manufacturer": {
    "en": "Tuya",
    "zh-CN": "涂鸦智能"
  },
  "platformId": "t5ai",
  "variantId": "t5ai",
  "peripheralPatterns": {
    "audio": [
      {
        "name": {
          "en": "Audio",
          "zh-CN": "音频"
        },
        "interface": "INTERNAL",
        "mounting": "onboard",
        "pinLocked": true,
        "pins": {
          "INTERNAL": [
            {
              "role": "spk_en",
              "gpio": 27,
              "activeLevel": "high"
            }
          ]
