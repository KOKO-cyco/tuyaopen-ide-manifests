              "role": "sck",
              "gpio": 22
            },
            {
              "role": "mosi",
              "gpio": 24
            },
            {
              "role": "cs",
              "gpio": 23
            },
            {
              "role": "dc",
              "gpio": 17
            },
            {
              "role": "rst",
              "gpio": 18
            },
            {
              "role": "bl",
              "gpio": 25
            }
          ]
        },
        "kconfig": {
          "T5AI_MINI_EX_MODULE_ST7735S_XLT": 1
        },
        "note": {
          "en": "BL active high.",
          "zh-CN": "背光高有效。"
        },
        "mounting": "accessory",
        "pinLocked": false,
        "id": "display-st7735s",
        "width": 160,
        "height": 80
      }
    ]
