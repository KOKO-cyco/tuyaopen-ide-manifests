    "audio": [
      {
        "name": {
          "en": "Audio",
          "zh-CN": "音频"
        },
        "interface": "INTERNAL",
        "mounting": "onboard",
        "pinLocked": true,
        "pins": {
          "INTERNAL": [
            {
              "role": "pa_ctrl",
              "gpio": 28,
              "activeLevel": "high"
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "AEC enabled. 2 audio ADCs (mic), 1 DAC. Speaker via MX1.25 connector (8Ω 1W/2W). pa_ctrl active low. MIC1 = microphone input, MIC2 = AEC reference, LP/LN = differential speaker output.",
          "zh-CN": "已启用 AEC。2 路音频 ADC（麦克风），1 路 DAC。扬声器通过 MX1.25 接口（8Ω 1W/2W）。pa_ctrl 低有效。MIC1 = 麦克风输入，MIC2 = AEC 回采，LP/LN = 差分喇叭输出。"
        },
        "id": "audio"
      }
    ],
    "display": [
