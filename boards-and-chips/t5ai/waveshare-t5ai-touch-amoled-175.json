{
  "schemaVersion": 1,
  "id": "waveshare-t5ai-touch-amoled-175",
  "name": {
    "en": "Waveshare T5AI Touch AMOLED 1.75\"",
    "zh-CN": "微雪 T5AI 1.75 寸触摸 AMOLED"
  },
  "summary": {
    "en": "Waveshare 1.75-inch 466×466 Touch AMOLED board based on T5-E1 module with CO5300 display driver, CST9217 capacitive touch, QMI8658 6-axis IMU, PCF85063 RTC, audio AEC with speaker output, battery management, Micro SD slot, and LVGL support.",
    "zh-CN": "基于 T5-E1 模组的微雪 1.75 寸 466×466 触摸 AMOLED 开发板，搭载 CO5300 显示驱动、CST9217 电容触控、QMI8658 六轴 IMU、PCF85063 实时时钟、音频 AEC 及扬声器输出、电池管理、Micro SD 卡槽，支持 LVGL。"
  },
  "brand": {
    "en": "Waveshare",
    "zh-CN": "微雪电子"
  },
  "manufacturer": {
    "en": "Waveshare",
    "zh-CN": "微雪电子"
  },
  "platformId": "t5ai",
  "variantId": "t5ai",
  "peripheralPatterns": {
    "audio": [
      {
        "model": null,
        "name": {
          "en": "Audio",
          "zh-CN": "音频"
        },
        "interface": "INTERNAL",
        "pins": {
          "INTERNAL": [
            {
              "role": "pa_ctrl",
              "gpio": 28
            }
          ],
          "ANALOG": [
            { "role": "spk_p", "gpio": null, "pin": "LP" },
            { "role": "spk_n", "gpio": null, "pin": "LN" },
            { "role": "mic1_p", "gpio": null, "pin": "MP1" },
            { "role": "mic1_n", "gpio": null, "pin": "MN1" },
            { "role": "mic2_p", "gpio": null, "pin": "MP2" },
            { "role": "mic2_n", "gpio": null, "pin": "MN2" },
            { "role": "micbias", "gpio": null, "pin": "MBS" }
          ]
        },
        "optional": false,
        "kconfig": null,
        "note": {
          "en": "AEC enabled. 2 audio ADCs (mic), 1 DAC. Speaker via MX1.25 connector (8Ω 1W/2W). pa_ctrl active low. MIC1 = microphone input, MIC2 = AEC reference, LP/LN = differential speaker output.",
          "zh-CN": "已启用 AEC。2 路音频 ADC（麦克风），1 路 DAC。扬声器通过 MX1.25 接口（8Ω 1W/2W）。pa_ctrl 低有效。MIC1 = 麦克风输入，MIC2 = AEC 回采，LP/LN = 差分喇叭输出。"
        }
      }
    ],
    "display": [
      {
        "model": "CO5300",
        "name": {
          "en": "1.75-inch AMOLED Display",
          "zh-CN": "1.75 寸 AMOLED 屏"
        },
        "resolution": "466x466",
        "interface": "QSPI",
        "pins": {
          "QSPI": [
            {
              "role": "sck",
              "gpio": 22
            },
            {
              "role": "cs",
              "gpio": 23
            },
            {
              "role": "sio0",
              "gpio": 24
            },
            {
              "role": "sio1",
              "gpio": 25
            },
            {
              "role": "sio2",
              "gpio": 26
            },
            {
              "role": "sio3",
              "gpio": 27
            },
            {
              "role": "rst",
              "gpio": 29
            },
            {
              "role": "te",
              "gpio": 31
            }
          ]
        },
        "optional": false,
        "kconfig": null,
        "note": {
          "en": "QSPI Port 0, 80 MHz. 16.7M colors, RGB565. LVGL supported with dual display buffer. Backlight controlled via CO5300 command.",
          "zh-CN": "QSPI 端口 0，80 MHz。1670 万色，RGB565。支持 LVGL 双显示缓冲。背光通过 CO5300 命令控制。"
        }
      }
    ],
    "touchpad": [
      {
        "model": "CST9217",
        "name": {
          "en": "Capacitive Touch",
          "zh-CN": "电容触控"
        },
        "interface": "I2C",
        "pins": {
          "I2C": [
            {
              "role": "scl",
              "gpio": 20
            },
            {
              "role": "sda",
              "gpio": 21
            },
            {
              "role": "int",
              "gpio": 42
            },
            {
              "role": "rst",
              "gpio": 43
            }
          ]
        },
        "optional": false,
        "kconfig": null,
        "note": {
          "en": "I2C0. Tempered glass with self-capacitance design. Mirror X/Y enabled.",
          "zh-CN": "I2C0。钢化玻璃自电容设计。X/Y 轴镜像已启用。"
        }
      }
    ],
    "imu": [
      {
        "model": "QMI8658",
        "name": {
          "en": "6-Axis IMU",
          "zh-CN": "六轴 IMU"
        },
        "axes": 6,
        "interface": "I2C",
        "pins": {
          "I2C": [
            {
              "role": "scl",
              "gpio": 20
            },
            {
              "role": "sda",
              "gpio": 21
            },
            {
              "role": "int1",
              "gpio": 7
            },
            {
              "role": "int2",
              "gpio": 9
            }
          ]
        },
        "optional": false,
        "kconfig": null,
        "note": {
          "en": "I2C0 shared with touch and RTC. 3-axis accelerometer + 3-axis gyroscope.",
          "zh-CN": "I2C0 与触控和 RTC 共享。三轴加速度计 + 三轴陀螺仪。"
        }
      }
    ],
    "rtc": [
      {
        "model": "PCF85063",
        "name": {
          "en": "Real-Time Clock",
          "zh-CN": "实时时钟"
        },
        "interface": "I2C",
        "pins": {
          "I2C": [
            {
              "role": "scl",
              "gpio": 20
            },
            {
              "role": "sda",
              "gpio": 21
            },
            {
              "role": "int",
              "gpio": 6
            }
          ]
        },
        "optional": false,
        "kconfig": null,
        "note": {
          "en": "I2C0 shared with touch and IMU.",
          "zh-CN": "I2C0 与触控和 IMU 共享。"
        }
      }
    ],
    "sd_card": [
      {
        "model": null,
        "name": {
          "en": "Micro SD Card",
          "zh-CN": "Micro SD 卡"
        },
        "interface": "SDIO",
        "pins": {
          "SDIO": [
            {
              "role": "clk",
              "gpio": 2
            },
            {
              "role": "cmd",
              "gpio": 3
            },
            {
              "role": "d0",
              "gpio": 4
            },
            {
              "role": "d1",
              "gpio": 5
            },
            {
              "role": "d2",
              "gpio": 10
            },
            {
              "role": "d3",
              "gpio": 11
            },
            {
              "role": "cd",
              "gpio": 8
            }
          ]
        },
        "optional": false,
        "kconfig": null,
        "note": {
          "en": "4-bit SDIO. Card detect on GPIO 8.",
          "zh-CN": "4 位 SDIO。卡检测引脚 GPIO 8。"
        }
      }
    ],
    "led": [
      {
        "model": null,
        "name": {
          "en": "Indicator LED",
          "zh-CN": "指示灯"
        },
        "count": 1,
        "interface": "GPIO",
        "pins": {
          "GPIO": [
            {
              "role": "led",
              "gpio": 47
            }
          ]
        },
        "optional": false,
        "kconfig": null,
        "note": {
          "en": "Active high. Also exposed on breakout header.",
          "zh-CN": "高有效。同时引出至排针。"
        }
      }
    ],
    "button": [
      {
        "name": {
          "en": "User Button",
          "zh-CN": "用户按键"
        },
        "count": 1,
        "interface": "GPIO",
        "pins": {
          "GPIO": [
            {
              "role": "key",
              "gpio": 12
            }
          ]
        },
        "optional": false,
        "kconfig": null,
        "note": {
          "en": "Active low with pull-up. Separate reset button also present.",
          "zh-CN": "低有效带上拉。另有独立复位按键。"
        }
      }
    ],
    "power": [
      {
        "model": null,
        "name": {
          "en": "Power Management",
          "zh-CN": "电源管理"
        },
        "interface": "GPIO",
        "pins": {
          "GPIO": [
            {
              "role": "sys_en",
              "gpio": 19
            },
            {
              "role": "sys_out",
              "gpio": 18
            },
            {
              "role": "bat_adc",
              "gpio": 13
            },
            {
              "role": "bat_chg",
              "gpio": 30
            }
          ]
        },
        "optional": false,
        "kconfig": null,
        "note": {
          "en": "sys_en: power latch, active high — hold high after boot. sys_out: power button detect, active low. bat_adc: battery voltage ADC. bat_chg: charge status.",
          "zh-CN": "sys_en：电源锁存，高有效——启动后须保持高电平。sys_out：电源按键检测，低有效。bat_adc：电池电压 ADC。bat_chg：充电状态。"
        }
      }
    ],
    "expansion": [
      {
        "model": null,
        "name": {
          "en": "8P 2.54mm Expansion Header",
          "zh-CN": "8P 2.54mm 扩展排针"
        },
        "interface": "GPIO",
        "pins": {
          "GPIO": [
            {
              "role": "io14",
              "gpio": 14
            },
            {
              "role": "io15",
              "gpio": 15
            },
            {
              "role": "io16",
              "gpio": 16
            },
            {
              "role": "io17",
              "gpio": 17
            },
            {
              "role": "io47",
              "gpio": 47
            }
          ]
        },
        "optional": true,
        "kconfig": null,
        "note": {
          "en": "8-pin 2.54mm header. Pin 1: 5V, Pin 2: GND, Pin 3: 3V3, Pin 4–8: IO14, IO15, IO16, IO17, IO47. IO47 also drives on-board LED.",
          "zh-CN": "8 针 2.54mm 排针。Pin 1: 5V、Pin 2: GND、Pin 3: 3V3、Pin 4–8: IO14、IO15、IO16、IO17、IO47。IO47 同时驱动板载 LED。"
        }
      },
      {
        "model": null,
        "name": {
          "en": "Expansion Pads",
          "zh-CN": "扩展焊盘"
        },
        "interface": "GPIO",
        "pins": {
