{
  "schemaVersion": 1,
  "id": "tuya-t5ai-pixel",
  "name": {
    "en": "Tuya T5AI Pixel",
    "zh-CN": "涂鸦 T5AI Pixel 板"
  },
  "summary": {
    "en": "T5AI evaluation board with audio AEC, 8× WS2812B pixel LED matrix, BMI270 6-axis IMU, and 3 user buttons",
    "zh-CN": "搭载音频 AEC、8 颗 WS2812B 像素灯珠矩阵、BMI270 六轴 IMU 和 3 颗用户按键的 T5AI 评估板"
  },
  "manufacturer": {
    "en": "Tuya",
    "zh-CN": "涂鸦智能"
  },
  "platformId": "t5ai",
  "variantId": "t5ai",
  "peripheralPatterns": {
    "audio": [
      {
        "name": {
          "en": "Audio",
          "zh-CN": "音频"
        },
        "interface": "INTERNAL",
        "mounting": "onboard",
        "pinLocked": true,
        "pins": {
          "INTERNAL": [
            {
              "role": "spk_en",
              "gpio": 42,
              "activeLevel": "high"
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "AEC enabled by default.",
          "zh-CN": "默认启用 AEC。"
        }
      }
    ],
    "imu": [
      {
        "model": "BMI270",
        "name": {
          "en": "6-Axis IMU",
          "zh-CN": "六轴 IMU"
        },
        "axes": 6,
        "interface": "I2C",
        "pins": {
          "I2C": [
            {
              "role": "scl",
              "gpio": 20
            },
            {
              "role": "sda",
              "gpio": 21
            }
          ]
        },
        "kconfig": null,
        "note": null,
        "mounting": "onboard",
        "pinLocked": true
      }
    ],
    "led-pixel": [
      {
        "name": {
          "en": "RGB LED Matrix",
          "zh-CN": "RGB 灯矩阵"
        },
        "interface": "SPI",
        "mounting": "onboard",
        "pinLocked": true,
        "model": "WS2812B",
        "count": 8,
        "pins": {
          "SPI": [
            {
              "role": "data",
              "gpio": 16
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "Timing strict — do not change SPI clock.",
          "zh-CN": "时序严格，勿修改 SPI 时钟频率。"
        }
      }
    ],
    "led": [
      {
        "name": {
          "en": "Indicator LED",
          "zh-CN": "指示灯"
        },
        "interface": "GPIO",
        "mounting": "onboard",
        "pinLocked": true,
        "count": 1,
        "pins": {
          "GPIO": [
            {
              "role": "led",
              "gpio": 47,
              "activeLevel": "high"
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "Active high.",
          "zh-CN": "高有效。"
        }
      }
    ],
    "button": [
      {
        "name": {
          "en": "User Buttons",
          "zh-CN": "用户按键"
        },
        "interface": "GPIO",
        "mounting": "onboard",
        "pinLocked": true,
        "count": 3,
        "pins": {
          "GPIO": [
            {
              "role": "ok",
              "gpio": 44,
              "activeLevel": "low"
            },
            {
              "role": "a",
              "gpio": 45,
              "activeLevel": "low"
            },
            {
              "role": "b",
              "gpio": 46,
              "activeLevel": "low"
            }
          ]
        },
        "kconfig": null,
        "note": {
          "en": "Active low.",
          "zh-CN": "低有效。"
        }
      }
    ]
  },
  "links": {
    "schematic": "https://oshwhub.com/tuyaopen/tuya-t5-pixels",
    "datasheet": {
      "en": "https://oshwhub.com/tuyaopen/tuya-t5-pixels",
      "zh-CN": "https://oshwhub.com/tuyaopen/tuya-t5-pixels"
    },
    "productPage": null
  },
  "tags": [
    "wifi",
    "ble",
    "ai",
    "audio",
    "led-pixel",
    "imu",
    "production-form"
  ],
  "kconfigId": "TUYA_T5AI_PIXEL",
  "scaffold": {
    "template": "tools/app_template/base",
    "baseConfig": {
      "CONFIG_BOARD_CHOICE_T5AI": "y",
      "CONFIG_BOARD_CHOICE_TUYA_T5AI_PIXEL": "y"
    }
  },
  "source": {
    "repo": "https://github.com/tuya/TuyaOpen/tree/master/boards/T5AI/TUYA_T5AI_PIXEL"
  }
}
