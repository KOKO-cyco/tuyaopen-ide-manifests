  "scaffold": {
    "template": "tools/app_template/base",
    "baseConfig": {
      "CONFIG_BOARD_CHOICE_T5AI": "y",
      "CONFIG_BOARD_CHOICE_TUYA_T5AI_EINK_NFC": "y"
    }
  },
