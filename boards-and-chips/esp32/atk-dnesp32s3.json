  "expansionConnectors": [
    {
      "id": "u2-spi-lcd",
      "name": {
        "en": "SPI LCD Connector (U2)",
        "zh-CN": "SPI LCD 接插件 (U2)"
      },
      "provides": [
        {
          "deviceClass": "display",
          "interface": "SPI",
          "pins": {
            "SPI": [
              {
                "role": "sck",
                "gpio": 12
              },
              {
                "role": "mosi",
                "gpio": 11
              },
              {
                "role": "cs",
                "gpio": 21
              },
              {
                "role": "dc",
                "gpio": 40
              },
              {
                "role": "bl",
                "expanderId": "io-expander-xl9555",
                "expanderPin": 8
              },
              {
                "role": "rst",
                "expanderId": "io-expander-xl9555",
                "expanderPin": 10
              },
              {
                "role": "power",
                "expanderId": "io-expander-xl9555",
                "expanderPin": 11
              }
            ]
          }
        }
      ],
      "note": {
        "en": "On-board SPI LCD header (U2, \"SPI LCD WIRELESS\"). Fixed SPI pinout; backlight/reset/power via XL9555. Attach any compatible SPI panel (the board ships an ST7789 on it — see the ST7789 accessory).",
        "zh-CN": "板载 SPI LCD 排针（U2，“SPI LCD WIRELESS”）。SPI 针脚固定;背光/复位/电源经 XL9555。可接任意兼容 SPI 屏(出厂配了一块 ST7789,见 ST7789 配件)。"
      }
    },
    {
