# OS / editor artifacts
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Local-only experimentation
*.local.json
/scratch/

# oh-my-claudecode internal state
.omc/
.claude/

# manifest-gen tool dependencies
tools/manifest-gen/node_modules/
# tool dependencies and compiled output (covers all tools/ subdirectories)
tools/*/node_modules/
tools/*/dist/
tools/*/out/
tools/*/build/
tools/*/.cache/

# Python bytecode caches (e.g. scripts/validate-skills-index.py)
__pycache__/
*.pyc

# JS / TS build artifacts — source maps, declaration files
*.js.map
*.css.map
*.d.ts
*.d.ts.map

# skill-script runtime caches (fetch_doc.py, search_help.py, ...)
skills/**/scripts/.doc_manifest_cache.json
skills/**/scripts/.doc_schema_cache/
